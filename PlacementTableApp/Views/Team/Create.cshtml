@model PlacementTableApp.Models.DTOs.TeamDTO

@{
    ViewData["Title"] = "Create Team";
}

<h1>Create Team</h1>

<form asp-action="Create" method="post">
    <div class="form-group">
        <label asp-for="Season"></label>
        <input class="form-control" asp-for="Season" />
    </div>
    <div class="form-group">
        <label asp-for="City"></label>
        <input class="form-control" asp-for="City" />
    </div>
    <div class="form-group">
        <label asp-for="Name"></label>
        <input class="form-control" asp-for="Name" />
    </div>
    <div class="form-group">
        <label asp-for="Division"></label>
        <input class="form-control" asp-for="Division" />
    </div>
    <div class="form-group">
        <label asp-for="League"></label>
        <input class="form-control" asp-for="League" />
    </div>
    <button type="submit" class="btn btn-primary">Create</button>
</form>
