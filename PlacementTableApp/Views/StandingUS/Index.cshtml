@model IEnumerable<PlacementTableApp.Models.DTOs.Standing>

@{
    ViewData["Title"] = "Standing MLB";
}

<h1>@ViewData["Title"]</h1>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Season</th>
            <th>Type</th>
            <th>Team Id</th>
            <th>City</th>
            <th>Name</th>
            <th>League</th>
            <th>Division</th>
            <th>Wins</th>
            <th>Losses</th>
            <th>Night Wins</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null)
        {
            foreach (var s in Model)
            {
                <tr>
                    <td>@s.Season</td>
                    <td>@s.SeasonType</td>
                    <td>@s.TeamId</td>
                    <td>@s.City</td>
                    <td>@s.Name</td>
                    <td>@s.League</td>
                    <td>@s.Division</td>
                    <td>@s.Wins</td>
                    <td>@s.Losses</td>
                    <td>@s.NightWins</td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="10">No standings available.</td>
            </tr>
        }
    </tbody>
</table>

<p>
    <a class="btn btn-primary" asp-controller="StandingUS" asp-action="StandingUS">Refresh</a>
</p>
