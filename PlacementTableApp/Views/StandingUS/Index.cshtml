@model IEnumerable<PlacementTableApp.Models.ViewModels.StandingView>

@{
    ViewData["Title"] = "Standing MLB";
    var filter_league = ViewData["FilterLeague"] as string;
    var filter_division = ViewData["FilterDivision"] as string;
}

<h1>@ViewData["Title"]</h1>


<h5>Vælg filter</h5>
@{
    if (filter_league != null)
    {
        <p>filter league: @filter_league</p>        
    }
    else
    {
        <a href="/StandingUS/AL">American League</a> <br />
        <a href="/StandingUS/NL">National league</a>        
    }
}

@if (filter_division != null)
{
    <p>filter division: @filter_division</p>
}
else
{
    @if (filter_league != null)
    {
        <a href="/StandingUS/@filter_league/central">Central</a> <br>
        <a href="/StandingUS/@filter_league/east">East</a> <br />
        <a href="/StandingUS/@filter_league/west">West</a> <br />
    }
}

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Season</th>
            <th>Type</th>
            <th>Team Id</th>
            <th>City</th>
            <th>Name</th>
            <th>League</th>
            <th>Division</th>
            <th>Wins</th>
            <th>Losses</th>
            <th>Night Wins</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null)
        {
            foreach (var s in Model)
            {
                <tr>
                    <td>@s.Season</td>
                    <td>@s.SeasonType</td>
                    <td>@s.TeamId</td>
                    <td>@s.City</td>
                    <td>@s.Name</td>
                    <td>@s.League</td>
                    <td>@s.Division</td>
                    <td>@s.Wins</td>
                    <td>@s.Losses</td>
                    <td>@s.NightWins</td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="10">No standings available.</td>
            </tr>
        }
    </tbody>
</table>

<p>
    <a class="btn btn-primary" asp-controller="StandingUS" asp-action="StandingUS">Refresh</a>
</p>
